title = " "
theme = "bamboo"

font-family = "Iosevka NFM"

font-size = 15
font-style = SemiBold

mouse-hide-while-typing = true
macos-option-as-alt = true
macos-titlebar-style = hidden

background-blur-radius = 100
background-opacity = 0.95
window-padding-x = 5
window-padding-y = 5

custom-shader = shaders/cursor_blaze_no_trail.glsl
custom-shader = shaders/cursor_smear.glsl

notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 30s

window-inherit-working-directory = false
tab-inherit-working-directory = false
split-inherit-working-directory = true

# Splits
keybind = ctrl+a>s=new_split:down
keybind = ctrl+a>v=new_split:right

# Navigate splits
keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>j=goto_split:bottom
keybind = ctrl+a>k=goto_split:top
keybind = ctrl+a>l=goto_split:right

# Resize splits
keybind = ctrl+a>ctrl+h=resize_split:left,20
keybind = ctrl+a>ctrl+j=resize_split:down,10
keybind = ctrl+a>ctrl+k=resize_split:up,10
keybind = ctrl+a>ctrl+l=resize_split:right,20

# Tabs
keybind = ctrl+a>ctrl+c=new_tab
keybind = ctrl+a>shift+h=previous_tab
keybind = ctrl+a>shift+l=next_tab

# Pane management
keybind = ctrl+a>z=toggle_split_zoom
keybind = ctrl+a>x=close_surface

# Send literal Ctrl-A to the terminal
keybind = ctrl+a>ctrl+a=text:\x01
# Cancel leader sequence
keybind = ctrl+a>escape=end_key_sequence
