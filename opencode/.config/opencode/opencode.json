{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": "ask",
    "edit": "allow",
    "grep": "allow",
    "patch": "allow",
    "read": "allow",
    "webfetch": "allow"
  },
  "provider": {
    "amazon-bedrock": {
      "options": {
        "profile": "bedrock"
      }
    },
    "ollama": {
      "models": {
        "llama3.1:8b": {
          "name": "llama3.1:8b"
        },
        "mistral-nemo:12b": {
          "name": "mistral-nemo:12b"
        },
        "qwen2.5-coder:14b": {
          "name": "qwen2.5-coder:14b"
        },
        "qwen2.5-coder:7b": {
          "name": "Qwen2.5-Coder 7B",
          "options": {
            "numCtx": 32768,
            "temperature": 0.7,
            "top_k": 40,
            "top_p": 0.9
          }
        },
        "qwen3:8b": {
          "name": "Qwen3 8B",
          "options": {
            "numCtx": 32768,
            "temperature": 0.1,
            "top_k": 20,
            "top_p": 0.9
          }
        }
      },
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    }
  }
}